<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_dark">

    <androidx.appcompat.widget.Toolbar android:id="@+id/toolbar"
        android:layout_width="match_parent" android:layout_height="?attr/actionBarSize"
        android:background="@color/bg_card" app:titleTextColor="@color/white"/>

    <ScrollView android:layout_width="match_parent" android:layout_height="match_parent">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Health Score -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:id="@+id/tvHealthScore"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Financial Health Score: --/100"
                        android:textSize="18sp" android:textStyle="bold" android:textColor="@color/green"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Based on spending patterns and budget adherence"
                        android:textSize="12sp" android:textColor="@color/white_50" android:layout_marginTop="4dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats row -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="12dp">

                <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="7-Day Total" android:textSize="11sp" android:textColor="@color/white_50"/>
                        <TextView android:id="@+id/tvWeekTotal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="₹0"
                            android:textSize="18sp" android:textStyle="bold" android:textColor="@color/purple_light"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Daily Avg" android:textSize="11sp" android:textColor="@color/white_50"/>
                        <TextView android:id="@+id/tvAvgDaily" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="₹0"
                            android:textSize="18sp" android:textStyle="bold" android:textColor="@color/teal"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="vertical" android:padding="14dp">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Month Total" android:textSize="11sp" android:textColor="@color/white_50"/>
                        <TextView android:id="@+id/tvMonthTotal" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="₹0"
                            android:textSize="18sp" android:textStyle="bold" android:textColor="@color/amber"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Top Merchant -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp" android:gravity="center_vertical">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏆 Top Merchant" android:textSize="13sp" android:textColor="@color/white_70"
                        android:layout_marginEnd="8dp"/>
                    <TextView android:id="@+id/tvTopMerchant" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:textSize="13sp" android:textStyle="bold" android:textColor="@color/amber"
                        android:gravity="end"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bar Chart -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📊 Daily Spending (Last 7 Days)"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white"
                        android:layout_marginBottom="8dp"/>
                    <com.github.mikephil.charting.charts.BarChart
                        android:id="@+id/barChart"
                        android:layout_width="match_parent" android:layout_height="200dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pie Chart -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🍩 Category Breakdown"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white"
                        android:layout_marginBottom="8dp"/>
                    <com.github.mikephil.charting.charts.PieChart
                        android:id="@+id/pieChart"
                        android:layout_width="match_parent" android:layout_height="260dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Line Chart -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="📈 30-Day Spending Trend"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white"
                        android:layout_marginBottom="8dp"/>
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/lineChart"
                        android:layout_width="match_parent" android:layout_height="200dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>


            <!-- Merchant Breakdown -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/bg_card" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🏪 Merchant Breakdown"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="@color/white"
                        android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tvMerchantBreakdown"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:text="No data yet..." android:textSize="13sp"
                        android:textColor="@color/white_70" android:lineSpacingMultiplier="1.6"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- AI Insights -->
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#1A7C3AED" app:cardCornerRadius="12dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="🧠 AI Spending Insights"
                        android:textSize="14sp" android:textStyle="bold" android:textColor="@color/purple_light"
                        android:layout_marginBottom="8dp"/>
                    <TextView android:id="@+id/tvInsights"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Scan SMS messages to get insights..."
                        android:textSize="13sp" android:textColor="@color/white_70"
                        android:lineSpacingMultiplier="1.5"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
