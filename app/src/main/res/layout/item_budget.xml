<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginHorizontal="0dp" android:layout_marginBottom="10dp"
    app:cardBackgroundColor="#1E293B" app:cardCornerRadius="14dp" app:cardElevation="4dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Row 1: Icon + Category + Status emoji -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical">
            <TextView android:id="@+id/tvIcon" android:layout_width="36dp" android:layout_height="36dp"
                android:textSize="22sp" android:gravity="center"
                android:background="#2A7C3AED" android:padding="4dp"/>
            <TextView android:id="@+id/tvCategory" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:layout_marginStart="10dp"
                android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="20sp"/>
        </LinearLayout>

        <!-- Row 2: Spent / Budget amounts -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="10dp">
            <TextView android:id="@+id/tvSpent" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="#94A3B8" android:textSize="13sp"/>
            <TextView android:id="@+id/tvLimit" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="#94A3B8" android:textSize="13sp"
                android:gravity="end"/>
        </LinearLayout>

        <!-- Progress bar -->
        <ProgressBar android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent" android:layout_height="10dp"
            android:layout_marginTop="8dp" android:max="100"
            android:progressBackgroundTint="#334155"
            android:background="#334155"/>

        <!-- Row 3: Remaining + Percent -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginTop="6dp">
            <TextView android:id="@+id/tvRemaining" android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textSize="13sp" android:textStyle="bold"/>
            <TextView android:id="@+id/tvPercent" android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="13sp" android:textStyle="bold"/>
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
